{
  "name": "@lordcraymen/rivetbench",
  "version": "1.0.1",
  "description": "Lightweight TypeScript framework for dual-exposed endpoints (REST + MCP).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lordcraymen/rivetbench.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify/server.js",
      "types": "./dist/adapters/fastify/server.d.ts"
    },
    "./rest": {
      "import": "./dist/adapters/rest/handler.js",
      "types": "./dist/adapters/rest/handler.d.ts"
    },
    "./mcp": {
      "import": "./dist/adapters/mcp/handler.js",
      "types": "./dist/adapters/mcp/handler.d.ts"
    },
    "./cli": {
      "import": "./dist/adapters/cli/adapter.js",
      "types": "./dist/adapters/cli/adapter.d.ts"
    },
    "./openapi": {
      "import": "./dist/application/openapi.js",
      "types": "./dist/application/openapi.d.ts"
    },
    "./pino": {
      "import": "./dist/adapters/pino/logger.js",
      "types": "./dist/adapters/pino/logger.d.ts"
    },
    "./http-transport": {
      "import": "./dist/adapters/http-transport/index.js",
      "types": "./dist/adapters/http-transport/index.d.ts"
    }
  },
  "bin": {
    "rivetbench": "./dist/bin/rivetbench.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "dev:rest": "tsx src/composition/standalone.ts",
    "dev:mcp": "tsx src/composition/standalone.ts",
    "dev:cli": "tsx src/bin/rivetbench.ts",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:bdd": "NODE_OPTIONS=\"--import tsx/esm\" npx cucumber-js test/features --import \"test/steps/*.ts\" --tags \"not @wip\"",
    "test:bdd:all": "NODE_OPTIONS=\"--import tsx/esm\" npx cucumber-js test/features --import \"test/steps/*.ts\"",
    "test:bdd:wip": "NODE_OPTIONS=\"--import tsx/esm\" npx cucumber-js test/features --import \"test/steps/*.ts\" --tags \"@wip\"",
    "bench": "vitest bench",
    "test:ci": "npm run test:unit && npm run test:bdd",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "keywords": [
    "rivetbench",
    "rest",
    "mcp",
    "fastify",
    "zod",
    "model-context-protocol",
    "rpc",
    "typescript",
    "dual-transport"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.7.4",
    "openapi-types": "^12.1.3",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@hono/node-server": "^1.19.11",
    "@koa/bodyparser": "^6.1.0",
    "@lordcraymen/adr-toolkit": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "hono": "^4.12.8",
    "husky": "^9.1.7",
    "koa": "^3.1.2",
    "lint-staged": "^16.2.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
